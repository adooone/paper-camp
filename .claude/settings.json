{
  "permissions": {
    "allow": [
      "Edit(src/**)",
      "Write(src/**)",
      "Edit(papercamp/**)",
      "Write(papercamp/**)",
      "Edit(*.json)",
      "Write(*.json)",
      "Edit(*.config.ts)",
      "Write(*.config.ts)",
      "Edit(*.config.js)",
      "Write(*.config.js)",
      "Bash(pnpm run check-types*)",
      "Bash(npx biome check*)",
      "Bash(git status*)",
      "Bash(git diff*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/src/cli/session-focus.ts\""
          }
        ]
      }
    ]
  }
}
